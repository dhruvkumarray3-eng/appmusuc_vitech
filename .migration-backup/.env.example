# Environment Configuration for RADHA MUSIC

# MongoDB Connection String
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/?retryWrites=true&w=majority&appName=app

# YouTube API Key (for search)
YOUTUBE_API_KEY=YOUR_YOUTUBE_API_KEY_HERE

# Telegram Bot Token (for bot integration)
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN_HERE

# Backend Server Port
PORT=3000

# Telegram Webhook URL (for production)
WEBHOOK_URL=https://yourdomain.com/telegram/webhook
